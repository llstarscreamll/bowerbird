{
  "name": "turno-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run infra:up && turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "deploy": "pnpm run build && turbo run deploy --filter=@turno/infra"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  },
  "packageManager": "pnpm@10.16.1"
}
