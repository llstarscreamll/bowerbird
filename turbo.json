{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "bin/**",
        "cdk.out/**"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    }
  }
}
